#: /home/minds3t/omnipkg/src/omnipkg/cli.py:338
msgid "  ⚠️  Stress Test Requires Python 3.11"
msgstr "StressテストにはPython 3.11が必要です"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:342
msgid "The omnipkg stress test only works in Python 3.11 environments."
msgstr "OmnipKGストレステストは、Python 3.11環境でのみ機能します。"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:343
msgid "To run the stress test:"
msgstr "ストレステストを実行するには："

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:350
msgid "  🚀 omnipkg Nuclear Stress Test - Runtime Version Swapping"
msgstr "🚀 omnipkg 核ストレステスト - ランタイムバージョン 交換"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:353
msgid "🎪 This demo showcases IMPOSSIBLE package combinations:"
msgstr "🎪このデモは、不可能なパッケージの組み合わせを紹介します。"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:354
msgid "   • Runtime swapping between numpy/scipy versions mid-execution"
msgstr "•numpy/scipyバージョン間のランタイムスワッピング中間"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:355
msgid "   • Different numpy+scipy combos (1.24.3+1.12.0 → 1.26.4+1.16.1)"
msgstr "•異なるNumpy+Scipy Combos（1.24.3+1.12.0→1.26.4+1.16.1）"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:357
msgid "   • Live PYTHONPATH manipulation without process restart"
msgstr "•プロセス再起動なしのライブPythonPath操作"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:358
msgid "   • Space-efficient deduplication (shows deduplication - normally"
msgstr "•空間効率の高い重複排除（通常は重複排除を示します"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:359
msgid "     we average ~60% savings, but less for C extensions/binaries)"
msgstr "私たちは平均約60％の節約ですが、拡張/バイナリの場合は少ない）"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:361
msgid "🤯 What makes this impossible with traditional tools:"
msgstr "craditional従来のツールでこれを不可能にするもの："

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:363
msgid "   • Switching versions requires environment restart"
msgstr "•バージョンの切り替えには、環境再起動が必要です"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:364
msgid "   • Dependency conflicts prevent coexistence"
msgstr "•依存関係の競合により、共存を防ぎます"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:367
msgid "✨ omnipkg does this LIVE, in the same Python process!"
msgstr "✨ omnipkg は、同じ Python プロセス内でこれをライブで実行します。"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:368
msgid "📊 Expected downloads: ~500MB | Duration: 30 seconds - 3 minutes"
msgstr "📊 予想されるダウンロード: ~500MB |持続時間: 30秒～3分"

#: /home/minds3t/omnipkg/src/omnipkg/cli.py:385
msgid "🔥 Starting stress test..."
msgstr "🔥ストレステストの開始..."

#: /home/minds3t/omnipkg/src/omnipkg/common_utils.py:532
msgid ""
"📡 Live streaming output (this may take several minutes for heavy "
"packages)..."
msgstr "📡ライブストリーミング出力（重いパッケージには数分かかる場合があります）..."

#: /home/minds3t/omnipkg/src/omnipkg/common_utils.py:534
msgid "🛑 Press Ctrl+C to safely cancel if needed"
msgstr "🛑 必要に応じて Ctrl+C を押して安全にキャンセルします"

